 
{
  "name": "shewadelivery-api-gateway",
  "version": "1.0.0",
  "description": "API Gateway for ShewaDelivery - Handles routing, auth, rate limiting, and caching",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "dev:debug": "nodemon --inspect=0.0.0.0:9229 src/server.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "test:integration": "jest --config jest.integration.config.js",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.js\"",
    "security:audit": "npm audit --audit-level=high",
    "security:scan": "snyk test",
    "build": "npm run lint && npm test",
    "prestart": "npm run build",
    "health": "node scripts/health-check.js",
    "seed:cache": "node scripts/seed-cache.js"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "compression": "^1.7.4",
    "jsonwebtoken": "^9.0.2",
    "redis": "^4.6.11",
    "amqplib": "^0.10.3",
    "axios": "^1.6.2",
    "dotenv": "^16.3.1",
    "winston": "^3.11.0",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "uuid": "^9.0.1",
    "crypto": "^1.0.1",
    "moment": "^2.29.4",
    "swagger-ui-express": "^5.0.0",
    "swagger-jsdoc": "^6.2.8",
    "prom-client": "^15.0.0",
    "circuit-breaker-js": "^0.0.1",
    "http-proxy-middleware": "^2.0.6"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "eslint": "^8.54.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.29.0",
    "prettier": "^3.1.0",
    "snyk": "^1.1290.0",
    "@faker-js/faker": "^8.3.1"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/shewadelivery/api-gateway"
  },
  "keywords": [
    "shewadelivery",
    "api-gateway",
    "food-delivery",
    "ethiopia"
  ],
  "author": "ShewaDelivery Team",
  "license": "MIT",
  "private": true
}