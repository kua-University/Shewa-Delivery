 

# .env.example
# ShewaDelivery Environment Configuration
# Copy this file to .env and update values for your environment

# ============================================
# Application Configuration
# ============================================
NODE_ENV=production
APP_NAME=ShewaDelivery
APP_VERSION=1.0.0
APP_URL=https://shewadelivery.com
API_URL=https://api.shewadelivery.com

# ============================================
# Service Ports
# ============================================
API_GATEWAY_PORT=3000
ORDER_SERVICE_PORT=3001
RESTAURANT_SERVICE_PORT=3002
PAYMENT_SERVICE_PORT=3003
AUTH_SERVICE_PORT=3004
NOTIFICATION_SERVICE_PORT=3005
DELIVERY_SERVICE_PORT=3006
FRONTEND_PORT=80

# ============================================
# Database Configuration - PostgreSQL
# ============================================
DB_HOST=postgres
DB_PORT=5432
DB_NAME=shewadelivery
DB_USER=shewa
DB_PASSWORD=CHANGE_ME_SECURE_PASSWORD
DB_POOL_MAX=20
DB_POOL_IDLE_TIMEOUT=30000
DB_CONNECTION_TIMEOUT=5000
DB_SSL=false

# PostgreSQL Replication (Production)
DB_REPLICA_HOST=postgres-replica
DB_REPLICA_PORT=5432

# ============================================
# Database Configuration - MongoDB
# ============================================
MONGODB_HOST=mongodb
MONGODB_PORT=27017
MONGODB_DB=shewadelivery
MONGODB_USER=shewa
MONGODB_PASSWORD=CHANGE_ME_SECURE_PASSWORD
MONGODB_URI=mongodb://shewa:CHANGE_ME_SECURE_PASSWORD@mongodb:27017/shewadelivery?authSource=admin
MONGODB_MAX_POOL_SIZE=50
MONGODB_MIN_POOL_SIZE=10

# ============================================
# Redis Configuration
# ============================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_SECURE_PASSWORD
REDIS_DB=0
REDIS_TLS=false

# Cache TTLs (seconds)
CACHE_TTL_MENU=300
CACHE_TTL_RESTAURANT_LIST=300
CACHE_TTL_SESSION=604800
CACHE_TTL_DRIVER_LOCATION=2
CACHE_TTL_PRODUCT_CATALOG=3600
CACHE_TTL_USER_PROFILE=900

# ============================================
# RabbitMQ Configuration
# ============================================
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672
RABBITMQ_USER=shewa
RABBITMQ_PASSWORD=CHANGE_ME_SECURE_PASSWORD
RABBITMQ_VHOST=/
RABBITMQ_URL=amqp://shewa:CHANGE_ME_SECURE_PASSWORD@rabbitmq:5672

# ============================================
# JWT Authentication (ASR-05)
# ============================================
JWT_SECRET=CHANGE_ME_JWT_SECRET_MIN_32_CHARS_LONG
JWT_REFRESH_SECRET=CHANGE_ME_REFRESH_SECRET_MIN_32_CHARS
JWT_EXPIRY=7d
REFRESH_TOKEN_EXPIRY=30d

# ============================================
# Chapa Payment Gateway (ASR-06)
# ============================================
CHAPA_API_KEY=chapa_live_CHANGE_ME
CHAPA_API_URL=https://api.chapa.co/v1
CHAPA_TIMEOUT=10000
CHAPA_RETRY_COUNT=3
CHAPA_WEBHOOK_SECRET=CHANGE_ME_WEBHOOK_SECRET

# ============================================
# Email Configuration (SMTP)
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@shewadelivery.com
SMTP_PASSWORD=CHANGE_ME_SMTP_PASSWORD
SMTP_FROM=ShewaDelivery <noreply@shewadelivery.com>

# ============================================
# SMS Configuration (Twilio)
# ============================================
TWILIO_ACCOUNT_SID=ACCHANGE_ME
TWILIO_AUTH_TOKEN=CHANGE_ME_TWILIO_TOKEN
TWILIO_PHONE_NUMBER=+251XXXXXXXXX

# ============================================
# Push Notifications (Firebase)
# ============================================
FCM_SERVICE_ACCOUNT_PATH=/app/firebase-service-account.json
FCM_API_KEY=CHANGE_ME_FCM_API_KEY

# ============================================
# Google Maps / Location Services
# ============================================
GOOGLE_MAPS_API_KEY=CHANGE_ME_GOOGLE_MAPS_KEY
MAP_PROVIDER=google
DEFAULT_LATITUDE=9.0054
DEFAULT_LONGITUDE=38.7636

# ============================================
# Rate Limiting
# ============================================
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_AUTH_WINDOW_MS=900000
RATE_LIMIT_AUTH_MAX_REQUESTS=10

# ============================================
# Logging & Monitoring
# ============================================
LOG_LEVEL=info
LOG_FORMAT=json
SENTRY_DSN=https://CHANGE_ME@sentry.io/CHANGE_ME
SENTRY_ENVIRONMENT=production

# ============================================
# CORS Configuration
# ============================================
CORS_ORIGINS=https://shewadelivery.com,https://api.shewadelivery.com,http://localhost:3000
CORS_CREDENTIALS=true

# ============================================
# AWS Configuration (af-south-1)
# ============================================
AWS_REGION=af-south-1
AWS_ACCESS_KEY_ID=CHANGE_ME_ACCESS_KEY
AWS_SECRET_ACCESS_KEY=CHANGE_ME_SECRET_KEY
AWS_S3_BUCKET=shewadelivery-assets
AWS_S3_BUCKET_LOGS=shewadelivery-logs
CLOUDFRONT_DISTRIBUTION_ID=E1234567890

# ============================================
# Kubernetes / EKS
# ============================================
K8S_NAMESPACE=shewadelivery
EKS_CLUSTER_NAME=shewadelivery-eks
ECR_REGISTRY=123456789012.dkr.ecr.af-south-1.amazonaws.com

# ============================================
# Frontend Configuration
# ============================================
REACT_APP_API_URL=https://api.shewadelivery.com
REACT_APP_WS_URL=wss://api.shewadelivery.com
REACT_APP_CHAPA_PUBLIC_KEY=chapa_public_CHANGE_ME
REACT_APP_GOOGLE_MAPS_API_KEY=CHANGE_ME_GOOGLE_MAPS_KEY
REACT_APP_ENABLE_PWA=true
REACT_APP_ENABLE_OFFLINE_MODE=true
REACT_APP_SENTRY_DSN=https://CHANGE_ME@sentry.io/CHANGE_ME
REACT_APP_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ============================================
# Internal API Keys (Service-to-Service)
# ============================================
INTERNAL_API_KEY=CHANGE_ME_INTERNAL_API_KEY

# ============================================
# Feature Flags
# ============================================
FEATURE_NEW_CHECKOUT=false
FEATURE_RECOMMENDATION_ENGINE=false
FEATURE_BATCH_ORDERING=true
FEATURE_SCHEDULED_ORDERS=false

# ============================================
# Performance Tuning
# ============================================
API_TIMEOUT=15000
API_RETRY_ATTEMPTS=3
KEEP_ALIVE_TIMEOUT=65000
HEADERS_TIMEOUT=65000

# ============================================
# Security
# ============================================
BCRYPT_ROUNDS=12
SESSION_SECRET=CHANGE_ME_SESSION_SECRET
COOKIE_SECURE=true
COOKIE_HTTP_ONLY=true
COOKIE_SAME_SITE=strict

# ============================================
# Development Only (don't use in production)
# ============================================
# NODE_ENV=development
# DEBUG=shewadelivery:*
# DISABLE_AUTH=false
# MOCK_PAYMENTS=true