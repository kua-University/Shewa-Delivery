 # .gitignore
# ShewaDelivery - Git Ignore File

# ============================================
# Dependencies
# ============================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ============================================
# Environment Variables
# ============================================
.env
.env.local
.env.development
.env.production
.env.test
.env.staging
.env.*.local

# ============================================
# Build Outputs
# ============================================
dist/
build/
out/
.next/
.nuxt/
.cache/
.parcel-cache/

# Backend builds
backend/*/dist/
backend/*/build/

# Frontend builds
frontend/build/
frontend/.next/

# ============================================
# Logs
# ============================================
logs/
*.log
*.log.*
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pm2-*.log
server.log

